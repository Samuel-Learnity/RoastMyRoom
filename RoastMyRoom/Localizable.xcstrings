{
  "sourceLanguage" : "en",
  "strings" : {
    "(%lld pts)" : {
      "comment" : "A label that shows the user's current points balance. The argument is the user's points balance.",
      "isCommentAutoGenerated" : true
    },
    "/10" : {
      "comment" : "A label that shows the maximum score of a task.",
      "isCommentAutoGenerated" : true
    },
    "%@ /10, %@" : {
      "comment" : "A label that reads the score and verdict. The argument is the string “%.1f”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ /10, %2$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A badge that shows the number of times the user has scanned a room.",
      "isCommentAutoGenerated" : true
    },
    "%lld%%" : {
      "comment" : "A label displaying a percentage value. The value is animated.",
      "isCommentAutoGenerated" : true
    },
    "+%@" : {
      "comment" : "A label showing the monetary impact of a tip. The argument is the string “%.1f”.",
      "isCommentAutoGenerated" : true
    },
